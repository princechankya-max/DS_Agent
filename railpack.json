{
  "$schema": "https://schema.railpack.com",
  "providers": ["node", "python"],
  "steps": {
    "install": {
      "commands": [
        "npm install",
        "pip install -r requirements.txt"
      ]
    },
    "build": {
      "commands": ["npm run build"]
    }
  },
  "deploy": {
    "startCommand": "NODE_ENV=production node backend/server.js"
  }
}
